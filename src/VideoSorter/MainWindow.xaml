<Window x:Class="VideoSorter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:VideoSorter.Views"
        xmlns:converters="clr-namespace:VideoSorter.Converters"
        Title="Video Sorter" Height="700" Width="1100"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewMouseDown="Window_PreviewMouseDown">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:FileSizeConverter x:Key="FileSizeConverter"/>
        <converters:TimeSpanToStringConverter x:Key="TimeSpanConverter"/>
        <converters:SortOptionConverter x:Key="SortOptionConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="400"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="280" MinWidth="180"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Player + Info panel -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Player area — single or side-by-side -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition x:Name="CompareColumn" Width="0"/>
                </Grid.ColumnDefinitions>

                <views:VideoPlayerView Grid.Column="0" DataContext="{Binding Player}"/>
                <Rectangle Grid.Column="1" Width="2" Fill="#555"
                           Visibility="{Binding IsComparing, Converter={StaticResource BoolToVis}}"/>
                <views:VideoPlayerView x:Name="ComparePlayerView" Grid.Column="2"
                                       DataContext="{Binding ComparePlayer}"
                                       Visibility="{Binding IsComparing, Converter={StaticResource BoolToVis}}"/>
            </Grid>

            <!-- Row 1: Info panel (hidden when comparing) -->
            <Border Grid.Row="1" Background="#252525" BorderBrush="#333" BorderThickness="0,1,0,0"
                    Padding="12,10"
                    Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsComparing}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Editable filename + buttons -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding EditFileName, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14" Padding="4,3" VerticalContentAlignment="Center">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding RenameCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1" Content="Copy to" Margin="6,0,0,0"
                                Command="{Binding CopyToCommand}"/>
                        <Button Grid.Column="2" Content="Move to" Margin="4,0,0,0"
                                Command="{Binding MoveToCommand}"/>
                        <Button Grid.Column="3" Content="Delete" Margin="4,0,0,0"
                                Command="{Binding DeleteFileCommand}"/>
                    </Grid>

                    <!-- Row 1: Format info -->
                    <TextBlock Grid.Row="1" Foreground="#AAA" FontSize="12" Margin="0,6,0,0"
                               Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                        <Run Text="{Binding SelectedInfo.Extension, Mode=OneWay}"/>
                        <Run Text=" | "/>
                        <Run Text="{Binding SelectedInfo.FileSize, Mode=OneWay, Converter={StaticResource FileSizeConverter}}"/>
                        <Run Text=" | "/>
                        <Run Text="{Binding SelectedInfo.Width, Mode=OneWay}"/><Run Text="x"/><Run Text="{Binding SelectedInfo.Height, Mode=OneWay}"/>
                        <Run Text=" | "/>
                        <Run Text="{Binding SelectedInfo.Duration, Mode=OneWay, Converter={StaticResource TimeSpanConverter}}"/>
                    </TextBlock>

                    <!-- Row 2: Tracks -->
                    <TextBlock Grid.Row="2" Foreground="#888" FontSize="11" Margin="0,3,0,0"
                               TextWrapping="Wrap"
                               Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                        <Run Text="Video: "/><Run Text="{Binding SelectedInfo.VideoCodecs, Mode=OneWay}"/>
                        <Run Text=" | Audio: "/><Run Text="{Binding SelectedInfo.AudioCodecs, Mode=OneWay}"/>
                    </TextBlock>

                    <!-- Row 3: Subtitles -->
                    <TextBlock Grid.Row="3" Foreground="#888" FontSize="11" Margin="0,2,0,0"
                               TextWrapping="Wrap"
                               Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                        <Run Text="Subtitles: "/><Run Text="{Binding SelectedInfo.SubtitleLanguages, Mode=OneWay}"/>
                    </TextBlock>

                    <!-- Row 4: Thumbnail strip -->
                    <ItemsControl Grid.Row="4" x:Name="InfoThumbnailStrip"
                                  ItemsSource="{Binding InfoThumbnails}"
                                  Margin="0,8,0,0"
                                  SizeChanged="InfoThumbnailStrip_SizeChanged">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.SeekToThumbnailCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Cursor="Hand" Background="Transparent" BorderThickness="0" Padding="0">
                                    <Image Source="{Binding Image}" Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Loading overlay -->
                    <TextBlock Grid.Row="1" Text="Loading metadata..." Foreground="#666" FontSize="12"
                               Visibility="{Binding IsLoadingInfo, Converter={StaticResource BoolToVis}}"/>
                </Grid>
            </Border>

            <!-- Row 2: Shared comparison controls (shown when comparing) -->
            <Grid Grid.Row="2" Background="#CC000000"
                  Visibility="{Binding IsComparing, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Seek bar -->
                <ProgressBar x:Name="CompareSeekBar" Grid.Row="0" Minimum="0" Maximum="1"
                             Value="{Binding Player.Position, Mode=OneWay}"
                             Margin="8,6,8,0" Height="6" Cursor="Hand"
                             Background="#444" Foreground="#0A84FF" BorderThickness="0"
                             MouseLeftButtonDown="CompareSeekBar_MouseDown"
                             MouseMove="CompareSeekBar_MouseMove"
                             MouseLeftButtonUp="CompareSeekBar_MouseUp"/>

                <!-- Controls row -->
                <Grid Grid.Row="1" Margin="8,2,8,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Play/Pause -->
                    <Button Grid.Column="0" Foreground="White"
                            Background="Transparent" BorderBrush="Transparent"
                            FontSize="18" Padding="8,2" Cursor="Hand"
                            Command="{Binding CompareTogglePlayPauseCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="&#x25B6;"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Player.IsPlaying}" Value="True">
                                        <Setter Property="Content" Value="&#x23F8;"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Stop -->
                    <Button Grid.Column="1" Content="&#x23F9;" FontSize="18"
                            Foreground="White" Background="Transparent" BorderBrush="Transparent"
                            Padding="8,2" Cursor="Hand"
                            Command="{Binding CompareStopCommand}"/>

                    <!-- Time display -->
                    <TextBlock Grid.Column="2" Foreground="#CCC" FontSize="12"
                               VerticalAlignment="Center" Margin="8,0">
                        <Run Text="{Binding Player.CurrentTime, Converter={StaticResource TimeSpanConverter}, Mode=OneWay}"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding Player.TotalTime, Converter={StaticResource TimeSpanConverter}, Mode=OneWay}"/>
                    </TextBlock>

                    <!-- Sync offset display -->
                    <TextBlock Grid.Column="4" Foreground="#AAA" FontSize="12"
                               VerticalAlignment="Center" Margin="4,0"
                               Text="Sync:"/>
                    <TextBlock Grid.Column="5" Foreground="#0A84FF" FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="4,0" MinWidth="70"
                               Text="{Binding SyncOffsetDisplay, Mode=OneWay}"/>

                    <!-- Sync [-] [+] buttons -->
                    <StackPanel Grid.Column="6" Orientation="Horizontal" Margin="4,0">
                        <Button Content="-" FontSize="14" FontWeight="Bold"
                                Foreground="White" Background="#444" BorderBrush="#555"
                                Padding="8,1" Cursor="Hand" MinWidth="28"
                                Command="{Binding AdjustSyncOffsetCommand}" CommandParameter="-"/>
                        <Button Content="+" FontSize="14" FontWeight="Bold"
                                Foreground="White" Background="#444" BorderBrush="#555"
                                Padding="8,1" Cursor="Hand" MinWidth="28" Margin="2,0,0,0"
                                Command="{Binding AdjustSyncOffsetCommand}" CommandParameter="+"/>
                    </StackPanel>

                    <!-- Unit ComboBox -->
                    <ComboBox Grid.Column="7" Margin="4,0"
                              ItemsSource="{Binding SyncUnits}"
                              SelectedItem="{Binding SelectedSyncUnit}"
                              MinWidth="80" FontSize="11" VerticalAlignment="Center"/>

                    <!-- Volume -->
                    <StackPanel Grid.Column="8" Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Vol" Foreground="#CCC" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ProgressBar x:Name="CompareVolumeBar" Minimum="0" Maximum="100"
                                     Value="{Binding Player.Volume, Mode=OneWay}" Width="60" Height="6"
                                     VerticalAlignment="Center" Cursor="Hand"
                                     Background="#444" Foreground="#0A84FF" BorderThickness="0"
                                     MouseLeftButtonDown="CompareVolumeBar_MouseDown"
                                     MouseMove="CompareVolumeBar_MouseMove"
                                     MouseLeftButtonUp="CompareVolumeBar_MouseUp"/>
                    </StackPanel>

                    <!-- Exit button -->
                    <Button Grid.Column="9" Content="Exit" FontSize="12"
                            Foreground="White" Background="#663333" BorderBrush="#884444"
                            Padding="10,3" Cursor="Hand" Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Command="{Binding ExitComparisonCommand}"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- SPLITTER -->
        <GridSplitter Grid.Column="1" Width="4" Background="#333"
                      HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext" Cursor="SizeWE"/>

        <!-- RIGHT: Folder bar + File list -->
        <Grid Grid.Column="2" Background="#222">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Folder navigation -->
            <views:FolderBarView Grid.Row="0" DataContext="{Binding FolderBar}"/>

            <!-- Sort + Filter button -->
            <Grid Grid.Row="1" Margin="6,0,6,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding VideoList.SortOptions}"
                          SelectedItem="{Binding VideoList.SelectedSort}"
                          FontSize="11">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource SortOptionConverter}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Column="1" Margin="4,0,0,0" Padding="6,2"
                        Command="{Binding VideoList.ToggleFilterCommand}"
                        ToolTip="Filter by name" FontSize="12"
                        Background="Transparent" BorderThickness="1"
                        BorderBrush="#555" Foreground="#CCC" Cursor="Hand">
                    <TextBlock Text="&#x1F50D;" FontSize="13"/>
                </Button>
            </Grid>

            <!-- Filter text input -->
            <TextBox Grid.Row="2" Margin="6,0,6,4"
                     Text="{Binding VideoList.FilterText, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="11" Padding="4,3"
                     Visibility="{Binding VideoList.IsFilterVisible, Converter={StaticResource BoolToVis}}"/>

            <!-- Compare controls -->
            <Grid Grid.Row="3" Margin="6,0,6,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ToggleButton x:Name="MultiSelectToggle" Grid.Column="0"
                              Content="Multi-select" Padding="6,3" FontSize="11" Cursor="Hand"
                              Background="Transparent" Foreground="#CCC" BorderBrush="#555"
                              Checked="MultiSelectToggle_Changed" Unchecked="MultiSelectToggle_Changed"/>
                <Button Grid.Column="1" Content="Compare" Margin="4,0,0,0"
                        Padding="6,3" FontSize="11" Cursor="Hand"
                        Background="#3A4A5A" Foreground="White" BorderBrush="#4A6A8A"
                        Command="{Binding EnterComparisonCommand}"
                        Visibility="{Binding VideoList.CanCompare, Converter={StaticResource BoolToVis}}"/>
            </Grid>

            <!-- File list -->
            <ListBox x:Name="FileListBox" Grid.Row="4"
                     ItemsSource="{Binding VideoList.Files}"
                     SelectedItem="{Binding VideoList.SelectedFile}"
                     SelectionChanged="FileListBox_SelectionChanged"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     HorizontalContentAlignment="Stretch"
                     Background="#222" BorderThickness="0">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Background="#2A2A2A" BorderBrush="#3A3A3A"
                                            BorderThickness="0,0,0,1" Padding="8,6">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#333"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#3A4A5A"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#4A6A8A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <!-- Folder item template -->
                            <Border x:Name="FolderPanel" Cursor="Hand"
                                    Background="Transparent"
                                    MouseLeftButtonUp="FolderItem_Click">
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="&#x1F4C1;" FontSize="14" VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding FileName}" FontSize="12"
                                               Foreground="#CCC" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Video item template -->
                            <StackPanel x:Name="VideoPanel">
                                <!-- Filename -->
                                <TextBlock Text="{Binding FileName}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#EEE"
                                           TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>
                                <!-- Thumbnail strip -->
                                <ItemsControl ItemsSource="{Binding Thumbnails}" Margin="0,0,0,4">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding}" Height="38" Stretch="Uniform"
                                                   Margin="0,0,2,0"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <!-- Size | Duration | Dimensions -->
                                <TextBlock Foreground="#AAA" FontSize="10.5" Margin="0,0,0,2"
                                           TextTrimming="CharacterEllipsis">
                                    <Run Text="{Binding FileSize, Mode=OneWay, Converter={StaticResource FileSizeConverter}}"/>
                                    <Run Text=" | "/>
                                    <Run Text="{Binding Duration, Mode=OneWay, Converter={StaticResource TimeSpanConverter}}"/>
                                    <Run Text=" | "/>
                                    <Run Text="{Binding Width, Mode=OneWay}"/><Run Text="x"/><Run Text="{Binding Height, Mode=OneWay}"/>
                                </TextBlock>
                                <!-- Codecs -->
                                <TextBlock Foreground="#888" FontSize="10" Margin="0,0,0,1"
                                           TextTrimming="CharacterEllipsis">
                                    <Run Text="V: "/><Run Text="{Binding VideoCodec, Mode=OneWay}"/>
                                    <Run Text="  A: "/><Run Text="{Binding AudioCodec, Mode=OneWay}"/>
                                </TextBlock>
                                <!-- Subtitles (hidden when empty) -->
                                <TextBlock x:Name="SubtitleLine" Foreground="#888" FontSize="10"
                                           TextTrimming="CharacterEllipsis">
                                    <Run Text="Subs: "/><Run Text="{Binding SubtitleInfo, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                        <DataTemplate.Triggers>
                            <!-- Show/hide based on IsFolder -->
                            <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                <Setter TargetName="VideoPanel" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsFolder}" Value="False">
                                <Setter TargetName="FolderPanel" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SubtitleInfo}" Value="">
                                <Setter TargetName="SubtitleLine" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Loading bar (after ListBox for z-order) -->
            <ProgressBar Grid.Row="4" VerticalAlignment="Top" Height="3"
                         IsIndeterminate="True" Background="Transparent"
                         Foreground="#4A6A8A" Panel.ZIndex="1"
                         Visibility="{Binding VideoList.IsLoading, Converter={StaticResource BoolToVis}}"/>
        </Grid>
    </Grid>
</Window>
