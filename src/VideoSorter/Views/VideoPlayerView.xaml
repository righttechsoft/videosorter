<UserControl x:Class="VideoSorter.Views.VideoPlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
             xmlns:converters="clr-namespace:VideoSorter.Converters">
    <UserControl.Resources>
        <converters:TimeSpanToStringConverter x:Key="TimeSpanConverter"/>
        <converters:CountToVisibilityConverter x:Key="CountToVis"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Background="Black">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Video surface -->
        <vlc:VideoView x:Name="VideoView" Grid.Row="0" MediaPlayer="{Binding MediaPlayer}">
            <!-- Overlay: near-transparent background for mouse events (WPF airspace) -->
            <Grid x:Name="Overlay" Background="#01000000"
                  Focusable="True" FocusVisualStyle="{x:Null}"
                  MouseLeftButtonDown="Overlay_MouseLeftButtonDown"/>
        </vlc:VideoView>

        <!-- Row 1: Control bar below video — always visible -->
        <Grid Grid.Row="1" Background="#CC000000"
              Visibility="{Binding ShowControls, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Seek bar -->
            <ProgressBar x:Name="SeekBar" Grid.Row="0" Minimum="0" Maximum="1"
                         Value="{Binding Position, Mode=OneWay}"
                         Margin="8,6,8,0" Height="6" Cursor="Hand"
                         Background="#444" Foreground="#0A84FF" BorderThickness="0"
                         MouseLeftButtonDown="SeekBar_MouseDown"
                         MouseMove="SeekBar_MouseMove"
                         MouseLeftButtonUp="SeekBar_MouseUp"/>

            <!-- Controls row -->
            <Grid Grid.Row="1" Margin="8,2,8,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Play/Pause -->
                <Button Grid.Column="0" Foreground="White"
                        Background="Transparent" BorderBrush="Transparent"
                        FontSize="18" Padding="8,2" Cursor="Hand"
                        Command="{Binding TogglePlayPauseCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Content" Value="&#x25B6;"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                    <Setter Property="Content" Value="&#x23F8;"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Stop -->
                <Button Grid.Column="1" Content="&#x23F9;" FontSize="18"
                        Foreground="White" Background="Transparent" BorderBrush="Transparent"
                        Padding="8,2" Cursor="Hand"
                        Command="{Binding StopCommand}"/>

                <!-- Time display -->
                <TextBlock Grid.Column="2" Foreground="#CCC" FontSize="12"
                           VerticalAlignment="Center" Margin="8,0">
                    <Run Text="{Binding CurrentTime, Converter={StaticResource TimeSpanConverter}, Mode=OneWay}"/>
                    <Run Text=" / "/>
                    <Run Text="{Binding TotalTime, Converter={StaticResource TimeSpanConverter}, Mode=OneWay}"/>
                </TextBlock>

                <!-- Volume -->
                <TextBlock Grid.Column="4" Text="Vol" Foreground="#CCC" FontSize="11"
                           VerticalAlignment="Center" Margin="4,0"/>
                <ProgressBar x:Name="VolumeBar" Grid.Column="5" Minimum="0" Maximum="100"
                             Value="{Binding Volume, Mode=OneWay}" Width="80" Height="6"
                             VerticalAlignment="Center" Margin="4,0" Cursor="Hand"
                             Background="#444" Foreground="#0A84FF" BorderThickness="0"
                             MouseLeftButtonDown="VolumeBar_MouseDown"
                             MouseMove="VolumeBar_MouseMove"
                             MouseLeftButtonUp="VolumeBar_MouseUp"/>

                <!-- 3D mode toggle -->
                <Button Grid.Column="6" Content="{Binding Mode3DLabel}"
                        Foreground="#CCC" Background="Transparent" BorderBrush="#555"
                        BorderThickness="1" FontSize="11" Padding="6,2"
                        Margin="8,0,0,0" Cursor="Hand" VerticalAlignment="Center"
                        ToolTip="Cycle 3D mode: Off → SBS → Top/Bottom"
                        Command="{Binding Cycle3DModeCommand}"/>

                <!-- Audio/subtitle track selectors -->
                <StackPanel Grid.Column="7" Orientation="Horizontal" Margin="8,0,0,0">
                    <ComboBox ItemsSource="{Binding AudioTracks}"
                              SelectedIndex="{Binding SelectedAudioTrackIndex}"
                              MinWidth="80" Margin="0,0,4,0"
                              Visibility="{Binding AudioTracks.Count, Converter={StaticResource CountToVis}}"/>
                    <ComboBox ItemsSource="{Binding SubtitleTracks}"
                              SelectedIndex="{Binding SelectedSubtitleTrackIndex}"
                              MinWidth="80"
                              Visibility="{Binding SubtitleTracks.Count, Converter={StaticResource CountToVis}}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
