<UserControl x:Class="VideoSorter.Views.VideoListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:VideoSorter.Views"
             xmlns:converters="clr-namespace:VideoSorter.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <!-- Status bar with progress -->
        <Grid VerticalAlignment="Top" Panel.ZIndex="1"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ProgressBar Grid.Row="0" Height="4"
                         Minimum="0" Maximum="{Binding ProgressTotal}"
                         Value="{Binding ProgressCurrent, Mode=OneWay}"
                         Background="#333" Foreground="#0078D4"/>
            <TextBlock Grid.Row="1" Text="{Binding StatusText}" Foreground="#AAA" FontSize="11"
                       Margin="8,3" HorizontalAlignment="Left"/>
        </Grid>

        <!-- Status when not loading -->
        <TextBlock Text="{Binding StatusText}" Foreground="#888" FontSize="11"
                   Margin="8,4" VerticalAlignment="Top" HorizontalAlignment="Left"
                   Panel.ZIndex="1"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>

        <!-- Video list -->
        <ScrollViewer Margin="0,24,0,0" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Videos}"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <views:VideoItemView DataContext="{Binding}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty state -->
        <TextBlock Text="No videos found. Browse to a folder containing video files."
                   Foreground="#666" FontSize="14"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Margin="0,40,0,0">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Videos.Count}" Value="0"/>
                                <Condition Binding="{Binding IsLoading}" Value="False"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible"/>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </Grid>
</UserControl>
